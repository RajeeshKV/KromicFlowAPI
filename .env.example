# Kromic Flow Environment Variables

# ASP.NET / Render
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# PostgreSQL / Supabase / Render Postgres
ConnectionStrings__DefaultConnection=Host=HOST;Port=5432;Database=DATABASE;Username=USERNAME;Password=PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT
Jwt__Key=replace-with-at-least-32-characters
Jwt__Issuer=KromicFlow
Jwt__Audience=KromicFlow
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# Meta / Instagram OAuth + Webhooks
# Get these from https://developers.facebook.com/apps/
# Create an app with "Instagram Basic Display" or "Instagram Graph API" product
Meta__AppId=YOUR_INSTAGRAM_APP_ID
Meta__AppSecret=YOUR_INSTAGRAM_APP_SECRET
# Must match exactly what you set in your Facebook App dashboard > Instagram > Products > Instagram Basic Display > Valid OAuth Redirect URIs
Meta__OAuthRedirectUri=https://your-api.onrender.com/api/v1/auth/callback
# For local development: http://localhost:5000/api/v1/auth/callback
# Frontend URL where users should be redirected after successful OAuth
Meta__FrontendRedirectUri=https://your-frontend-domain.com/auth/callback
# For local development: http://localhost:3000/auth/callback
Meta__WebhookVerifyToken=YOUR_WEBHOOK_VERIFY_TOKEN
Meta__WebhookAppSecret=YOUR_WEBHOOK_APP_SECRET
Meta__GraphApiBaseUrl=https://graph.instagram.com/v20.0
Meta__ApiBaseUrl=https://api.instagram.com

# Brevo email notifications
Brevo__BaseUrl=https://api.brevo.com
Brevo__ApiKey=
Brevo__SenderEmail=
Brevo__SenderName=Kromic Flow

# Platform configuration
# Admin bootstrap endpoint is always available until the first admin is created.
Platform__TermsVersion=2026-07-18
Platform__DefaultPlanCode=free
Platform__AdminBootstrapKey=replace-with-one-time-admin-setup-key

# CORS. Comma-separated origins.
Cors__AllowedOrigins=https://your-frontend-domain.com,https://admin.your-frontend-domain.com

# Razorpay — Subscription Payments
# Get keys from https://dashboard.razorpay.com/app/website-app-settings/api-keys
# Use rzp_test_ keys for development, rzp_live_ keys for production
# Set Razorpay__Enabled=false to bypass all payment processing (safe for dev without keys)
Razorpay__Enabled=false
Razorpay__KeyId=rzp_test_XXXXXXXXXXXX
Razorpay__KeySecret=YOUR_RAZORPAY_KEY_SECRET
# Webhook secret: Dashboard → Webhooks → Secret (set when creating the webhook endpoint)
Razorpay__WebhookSecret=YOUR_RAZORPAY_WEBHOOK_SECRET
Razorpay__ApiBaseUrl=https://api.razorpay.com/v1
# 0 = unlimited recurring cycles; 12 = charge for 12 months then stop
Razorpay__DefaultTotalCount=0




{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=kromicflow;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "local-development-secret-at-least-32-characters",
    "Issuer": "KromicFlow",
    "Audience": "KromicFlow",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Meta": {
    "AppId": "YOUR_INSTAGRAM_APP_ID",
    "AppSecret": "YOUR_INSTAGRAM_APP_SECRET",
    "OAuthRedirectUri": "http://localhost:5000/api/v1/auth/callback",
    "FrontendRedirectUri": "https://flow.kromic.in/auth/callback",
    "MobileRedirectUri": "kromicflow://auth/callback",
    "WebhookVerifyToken": "YOUR_WEBHOOK_VERIFY_TOKEN",
    "WebhookAppSecret": "YOUR_WEBHOOK_APP_SECRET",
    "GraphApiBaseUrl": "https://graph.instagram.com/v20.0",
    "ApiBaseUrl": "https://api.instagram.com"
  },
  "Brevo": {
    "BaseUrl": "https://api.brevo.com",
    "ApiKey": "",
    "SenderEmail": "",
    "SenderName": "Kromic Flow"
  },
  "Platform": {
    "TermsVersion": "2026-07-18",
    "DefaultPlanCode": "free",
    "AdminBootstrapKey": "",
    "MobileDeepLinkScheme": "kromicflow",
    "MobileOAuthCallbackPath": "auth/callback"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"],
    "AllowMobileSchemes": true,
    "AllowExpoGo": true,
    "MobileOriginPatterns": ["kromicflow://", "exp://"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}

